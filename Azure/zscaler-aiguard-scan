<!--
This APIM policy fragment is designed to be included in the inbound and outbound processing of an API. 
It scans either the incoming request prompt or the outgoing response from a Large Language Model (LLM) 
for security threats using the Zscaler AI Guard DAS service.

## Pre-requisites:
- AIGUARD-API-KEY named value must be defined (secret)
- AIGUARD-CLOUD named value must be defined (us1, us2, eu1, eu2)
- AIGUARD-POLICY-ID named value (optional - will auto-resolve if not provided)

## Features:
- Scans either the prompt or the response based on the `ScanType` variable
- Handles both prompt and response scanning in a single fragment
- Session tracking using x-session-id header (groups conversations)
- Detailed error messages when requests are blocked
- Configurable fail-open or fail-closed behavior
- Transaction ID tracking for audit correlation

## Context Variables:
- `ScanType`: (string) "prompt" or "response". Defaults to "prompt"
- `currentPolicy`: (string) AI Guard policy ID. If not provided, uses auto-resolution
- `appName`: (string) Application name. Defaults to "Azure-APIM-Gateway"
- `FailOpen`: (boolean) `true` to allow traffic if scanner unavailable, `false` to block. Defaults to `false`
- `aiguardDescriptions`: (JObject) Custom error messages for detected threats. Optional.

## Usage:

### Inbound Example:
```xml
<inbound>
    <base />
    <set-variable name="aiguardDescriptions" value="@{
        return new JObject(
            new JProperty("toxicity", "Inappropriate content detected."),
            new JProperty("injection", "Security threat detected."),
            new JProperty("pii", "Sensitive information detected.")
        );
    }" />
    <set-variable name="ScanType" value="prompt" />
    <set-variable name="currentPolicy" value="760" />
    <set-variable name="FailOpen" value="true" />
    <include-fragment fragment-id="zscaler-aiguard-scan" />
</inbound>
```

### Outbound Example:
```xml
<outbound>
    <base />
    <set-variable name="ScanType" value="response" />
    <set-variable name="currentPolicy" value="760" />
    <include-fragment fragment-id="zscaler-aiguard-scan" />
</outbound>
```
-->
<fragment>
    <!--
    Define default error messages for each detector type.
    These can be overridden by setting the `aiguardDescriptions` context variable.
    -->
    <set-variable name="scanDescriptions" value="@{
        return new JObject(
            new JProperty("toxicity", "This contains inappropriate or harmful content."),
            new JProperty("injection", "This contains content that appears to be a security threat."),
            new JProperty("pii", "This contains sensitive personal information."),
            new JProperty("secrets", "This contains sensitive credentials or API keys."),
            new JProperty("gibberish", "This contains invalid or nonsensical content."),
            new JProperty("malicious_url", "This contains potentially malicious URLs."),
            new JProperty("off_topic", "This contains content outside the allowed scope."),
            new JProperty("competition", "This contains questions about competitors."),
            new JProperty("data_leakage", "This contains unauthorized data disclosure.")
        );
    }" />
    
    <choose>
        <when condition="@(
            context.Request.Method.Equals(&quot;POST&quot;, StringComparison.OrdinalIgnoreCase) && 
            (context.Request.OriginalUrl.Path.EndsWith(&quot;/completions&quot;, StringComparison.OrdinalIgnoreCase) || 
             context.Request.OriginalUrl.Path.EndsWith(&quot;/chat/completions&quot;, StringComparison.OrdinalIgnoreCase) ||
             context.Request.OriginalUrl.Path.EndsWith(&quot;/responses&quot;, StringComparison.OrdinalIgnoreCase))
        )">
            <!--
            Prepare common request metadata
            -->
            <set-variable name="requestMetadata" value="@{
                var body = context.Request.Body.As<JObject>(preserveContent: true);
                // Extract model name
                string model = (body != null && body.ContainsKey(&quot;model&quot;)) ? body[&quot;model&quot;].ToString() : &quot;unknown-model&quot;;
                // Application name defaults to APIM-Gateway
                string appName = &quot;APIM-&quot; + (string)context.Variables.GetValueOrDefault(&quot;appName&quot;, &quot;Gateway&quot;);
                // Session ID for conversation tracking
                string sessionId = context.Request.Headers.GetValueOrDefault(&quot;x-session-id&quot;, context.RequestId.ToString() ?? &quot;no-id&quot;);
                
                return new JObject(
                    new JProperty(&quot;session_id&quot;, sessionId),
                    new JProperty(&quot;app_name&quot;, appName),
                    new JProperty(&quot;ai_model&quot;, model),
                    new JProperty(&quot;user_ip&quot;, context.Request.IpAddress),
                    new JProperty(&quot;user_id&quot;, context.Request.Headers.GetValueOrDefault(&quot;x-user-id&quot;, &quot;anonymous&quot;))
                );
            }" />
            
            <!--
            Determine if scanning should occur
            -->
            <set-variable name="shouldScan" value="@{
                string type = context.Variables.GetValueOrDefault<string>(&quot;ScanType&quot;, &quot;prompt&quot;);
                
                if (type == &quot;prompt&quot;) {
                    return true; // Always scan prompts
                } 
                else if (type == &quot;response&quot;) {
                    // Only scan responses if backend succeeded
                    return context.Response != null && context.Response.StatusCode == 200;
                }
                
                return false;
            }" />
            
            <choose>
                <when condition="@((bool)context.Variables[&quot;shouldScan&quot;])">
                    <!--
                    Extract content to scan based on ScanType
                    -->
                    <choose>
                        <!-- PROMPT SCANNING (Inbound) -->
                        <when condition="@(context.Variables.GetValueOrDefault<string>(&quot;ScanType&quot;, &quot;prompt&quot;) == &quot;prompt&quot;)">
                            <set-variable name="scanContent" value="@{
                                try {
                                    var body = context.Request.Body.As<JObject>(preserveContent: true);
                                    string content = &quot;&quot;;
                                    
                                    // Handle different OpenAI API formats
                                    if (body[&quot;input&quot;] != null) {
                                        // Completions API
                                        content = body[&quot;input&quot;].ToString();
                                    } else if (body[&quot;messages&quot;] != null) {
                                        // Chat completions API - get last user message
                                        var messages = body[&quot;messages&quot;] as JArray;
                                        if (messages != null && messages.Count > 0) {
                                            content = messages.Last[&quot;content&quot;]?.ToString() ?? &quot;&quot;;
                                        }
                                    }
                                    
                                    return content;
                                } catch {
                                    return &quot;&quot;;
                                }
                            }" />
                            <set-variable name="scanDirection" value="IN" />
                        </when>
                        
                        <!-- RESPONSE SCANNING (Outbound) -->
                        <otherwise>
                            <set-variable name="scanContent" value="@{
                                try {
                                    var body = context.Response.Body.As<JObject>(preserveContent: true);
                                    string content = &quot;&quot;;
                                    
                                    // Handle different OpenAI response formats
                                    if (body[&quot;output&quot;] != null) {
                                        // Output format
                                        var output = body[&quot;output&quot;] as JArray;
                                        if (output != null && output.Count > 0) {
                                            content = output.Last[&quot;content&quot;]?.Last?[&quot;text&quot;]?.ToString() ?? &quot;&quot;;
                                        }
                                    } else if (body[&quot;choices&quot;] != null) {
                                        // Choices format (chat completions)
                                        var choices = body[&quot;choices&quot;] as JArray;
                                        if (choices != null && choices.Count > 0) {
                                            content = choices.Last[&quot;message&quot;]?[&quot;content&quot;]?.ToString() ?? &quot;&quot;;
                                        }
                                    }
                                    
                                    return content;
                                } catch {
                                    return &quot;&quot;;
                                }
                            }" />
                            <set-variable name="scanDirection" value="OUT" />
                        </otherwise>
                    </choose>
                    
                    <!--
                    Call Zscaler AI Guard API
                    -->
                    <send-request id="aiguard-scan" mode="new" response-variable-name="aiguardScanResponse" timeout="10" ignore-error="true">
                        <set-url>@{
                            string cloud = &quot;{{AIGUARD-CLOUD}}&quot;;
                            return $&quot;https://api.{cloud}.zseclipse.net/v1/detection/execute-policy&quot;;
                        }</set-url>
                        <set-method>POST</set-method>
                        <set-header name="Authorization" exists-action="override">
                            <value>Bearer {{AIGUARD-API-KEY}}</value>
                        </set-header>
                        <set-header name="Content-Type" exists-action="override">
                            <value>application/json</value>
                        </set-header>
                        <set-body>@{
                            var scanContent = (string)context.Variables.GetValueOrDefault(&quot;scanContent&quot;, &quot;&quot;);
                            var direction = (string)context.Variables.GetValueOrDefault(&quot;scanDirection&quot;, &quot;IN&quot;);
                            var policyId = context.Variables.GetValueOrDefault(&quot;currentPolicy&quot;, &quot;{{AIGUARD-POLICY-ID}}&quot;);
                            
                            var requestBody = new JObject(
                                new JProperty(&quot;content&quot;, scanContent),
                                new JProperty(&quot;direction&quot;, direction)
                            );
                            
                            // Add policy ID if provided
                            if (!string.IsNullOrEmpty(policyId.ToString())) {
                                requestBody.Add(&quot;policyId&quot;, int.Parse(policyId.ToString()));
                            }
                            
                            return requestBody.ToString();
                        }</set-body>
                    </send-request>
                    
                    <!--
                    Process AI Guard response
                    -->
                    <choose>
                        <!-- AI Guard API returned successfully -->
                        <when condition="@(context.Variables.ContainsKey(&quot;aiguardScanResponse&quot;) && ((IResponse)context.Variables[&quot;aiguardScanResponse&quot;]).StatusCode == 200)">
                            <choose>
                                <!-- AI Guard returned BLOCK action -->
                                <when condition="@{
                                    var scanResponse = ((IResponse)context.Variables[&quot;aiguardScanResponse&quot;]).Body.As<JObject>(preserveContent: true);
                                    string action = scanResponse[&quot;action&quot;]?.ToString() ?? &quot;ALLOW&quot;;
                                    return action.Equals(&quot;BLOCK&quot;, StringComparison.OrdinalIgnoreCase);
                                }">
                                    <!--
                                    Build detailed error response
                                    -->
                                    <set-variable name="errorBody" value="@{
                                        var scanResponse = ((IResponse)context.Variables[&quot;aiguardScanResponse&quot;]).Body.As<JObject>(preserveContent: true);
                                        var response = new JObject();
                                        
                                        // 1. Set error header based on scan type
                                        var scanType = context.Variables.GetValueOrDefault<string>(&quot;ScanType&quot;, &quot;prompt&quot;);
                                        if (scanType == &quot;prompt&quot;) {
                                            response.Add(&quot;error&quot;, &quot;🛡️ ZSCALER AI GUARD SECURITY ALERT: REQUEST BLOCKED&quot;);
                                        } else {
                                            response.Add(&quot;error&quot;, &quot;🛡️ ZSCALER AI GUARD SECURITY ALERT: RESPONSE BLOCKED&quot;);
                                        }
                                        
                                        // 2. Get custom descriptions (or use defaults)
                                        var descriptions = context.Variables.GetValueOrDefault<object>(&quot;aiguardDescriptions&quot;) as JObject;
                                        if (descriptions == null) {
                                            descriptions = context.Variables.GetValueOrDefault<object>(&quot;scanDescriptions&quot;) as JObject;
                                        }
                                        
                                        // 3. Extract detector responses
                                        var detectorResponses = scanResponse[&quot;detectorResponses&quot;] as JObject;
                                        var details = new JObject();
                                        
                                        if (detectorResponses != null) {
                                            foreach (JProperty detector in detectorResponses.Properties()) {
                                                var detectorData = detector.Value as JObject;
                                                if (detectorData != null && 
                                                    detectorData[&quot;triggered&quot;] != null && 
                                                    (bool)detectorData[&quot;triggered&quot;] == true) {
                                                    
                                                    string detectorName = detector.Name;
                                                    
                                                    // Use custom description if available
                                                    if (descriptions != null && descriptions[detectorName] != null) {
                                                        details.Add(detectorName, descriptions[detectorName]);
                                                    } else {
                                                        details.Add(detectorName, true);
                                                    }
                                                }
                                            }
                                        }
                                        
                                        response.Add(&quot;details&quot;, details);
                                        
                                        // 4. Add severity and transaction ID
                                        if (scanResponse[&quot;severity&quot;] != null) {
                                            response[&quot;details&quot;][&quot;severity&quot;] = scanResponse[&quot;severity&quot;];
                                        }
                                        if (scanResponse[&quot;transactionId&quot;] != null) {
                                            response[&quot;details&quot;][&quot;transaction_id&quot;] = scanResponse[&quot;transactionId&quot;];
                                        }
                                        
                                        return response.ToString();
                                    }" />
                                    
                                    <!--
                                    Return 403 Forbidden response
                                    -->
                                    <return-response>
                                        <set-status code="403" reason="Forbidden" />
                                        <set-header name="Content-Type" exists-action="override">
                                            <value>application/json</value>
                                        </set-header>
                                        <set-body>@(context.Variables.GetValueOrDefault<string>(&quot;errorBody&quot;))</set-body>
                                    </return-response>
                                </when>
                                
                                <!-- AI Guard returned ALLOW - continue -->
                                <otherwise>
                                    <trace source="ZscalerAIGuard" severity="information">
                                        <message>@{
                                            var scanResponse = ((IResponse)context.Variables[&quot;aiguardScanResponse&quot;]).Body.As<JObject>(preserveContent: true);
                                            var scanType = context.Variables.GetValueOrDefault<string>(&quot;ScanType&quot;, &quot;prompt&quot;);
                                            var transactionId = scanResponse[&quot;transactionId&quot;]?.ToString() ?? &quot;unknown&quot;;
                                            return $&quot;AI Guard scan passed: type={scanType}, action=ALLOW, txn={transactionId}&quot;;
                                        }</message>
                                    </trace>
                                </otherwise>
                            </choose>
                        </when>
                        
                        <!--
                        AI Guard API unavailable or returned error
                        Handle based on FailOpen configuration
                        -->
                        <otherwise>
                            <choose>
                                <!-- Fail-Closed: Block traffic if AI Guard unavailable -->
                                <when condition="@(Convert.ToBoolean(context.Variables.GetValueOrDefault<object>(&quot;FailOpen&quot;, false)) == false)">
                                    <return-response>
                                        <set-status code="503" reason="Service Unavailable" />
                                        <set-header name="Content-Type" exists-action="override">
                                            <value>application/json</value>
                                        </set-header>
                                        <set-body>{ 
                                            "error": "🛡️ ZSCALER AI GUARD SECURITY ALERT: Security scanner unavailable", 
                                            "details": {
                                                "message": "Request blocked for safety. AI Guard service is currently unavailable."
                                            }
                                        }</set-body>
                                    </return-response>
                                </when>
                                
                                <!-- Fail-Open: Allow traffic if AI Guard unavailable -->
                                <otherwise>
                                    <trace source="ZscalerAIGuard" severity="warning">
                                        <message>@{
                                            var scanType = context.Variables.GetValueOrDefault<string>(&quot;ScanType&quot;, &quot;prompt&quot;);
                                            return $&quot;AI Guard scanner unavailable for {scanType} scan. Failing open (allowing traffic).&quot;;
                                        }</message>
                                    </trace>
                                </otherwise>
                            </choose>
                        </otherwise>
                    </choose>
                </when>
                
                <!-- No scan needed -->
                <otherwise>
                    <trace source="ZscalerAIGuard" severity="information">
                        <message>Scan not required for this request type or response status</message>
                    </trace>
                </otherwise>
            </choose>
        </when>
        
        <!-- Request type not supported -->
        <otherwise>
            <trace source="ZscalerAIGuard" severity="information">
                <message>Request type not configured for AI Guard scanning</message>
            </trace>
        </otherwise>
    </choose>
</fragment>
