<!--
This APIM policy fragment is designed to be included in the inbound and outbound processing of an API. 
It scans either the incoming request prompt or the outgoing response from a Large Language Model (LLM) 
for security threats using the Zscaler AI Guard service.

## Pre-requisites:
 AIGUARD-API-KEY named value must be defined (secret)
 AIGUARD-CLOUD named value must be defined (us1, us2, eu1, eu2)

## Features:
- Scans either the prompt or the response based on the `ScanType` variable.
- Handles both prompt and response scanning in a single fragment.
- Session tracking using x-session-id header (groups conversations).
- Detailed error messages when requests are blocked.
- Configurable fail-open or fail-closed behavior.
- Transaction ID tracking for audit correlation.

## Context Variables:
- `ScanType`: (string) "prompt" or "response". Defaults to "prompt".
- `currentPolicy`: (string) AI Guard policy ID. If not provided, uses auto-resolution.
- `appName`: (string) Application name. Defaults to "Azure-APIM-Gateway".
- `FailOpen`: (boolean) `true` to allow traffic if scanner unavailable, `false` to block. Defaults to `false`.
- `aiguardDescriptions`: (JObject) Custom error messages for detected threats. Optional.

## Usage:

### Inbound Example:
```xml
<inbound>
    <base />
    <set-variable name="aiguardDescriptions" value="@{
        return new JObject(
            new JProperty("toxicity", "Inappropriate content detected."),
            new JProperty("injection", "Security threat detected."),
            new JProperty("pii", "Sensitive information detected.")
        );
    }" />
    <set-variable name="ScanType" value="prompt" />
    <set-variable name="FailOpen" value="true" />
    <include-fragment fragment-id="zscaler-aiguard-scan" />
</inbound>
```

### Outbound Example:
```xml
<outbound>
    <base />
    <set-variable name="ScanType" value="response" />
    <include-fragment fragment-id="zscaler-aiguard-scan" />
</outbound>
```
-->
<fragment>
	<set-variable name="scanDescriptions" value="@{
        return new JObject(
            new JProperty("toxicity", "This contains inappropriate or harmful content."),
            new JProperty("injection", "This contains content that appears to be a security threat."),
            new JProperty("pii", "This contains sensitive personal information."),
            new JProperty("secrets", "This contains sensitive credentials or API keys."),
            new JProperty("gibberish", "This contains invalid or nonsensical content."),
            new JProperty("malicious_url", "This contains potentially malicious URLs."),
            new JProperty("off_topic", "This contains content outside the allowed scope."),
            new JProperty("competition", "This contains questions about competitors."),
            new JProperty("data_leakage", "This contains unauthorized data disclosure.")
        );
    }" />
	<choose>
		<when condition="@(
        context.Request.Method.Equals("POST", StringComparison.OrdinalIgnoreCase) && 
        (context.Request.OriginalUrl.Path.EndsWith("/completions", StringComparison.OrdinalIgnoreCase) || 
         context.Request.OriginalUrl.Path.EndsWith("/chat/completions", StringComparison.OrdinalIgnoreCase) ||
         context.Request.OriginalUrl.Path.EndsWith("/responses", StringComparison.OrdinalIgnoreCase))
    )">
			<set-variable name="requestMetadata" value="@{
            var body = context.Request.Body.As<JObject>(preserveContent: true);
            string model = (body != null && body.ContainsKey("model")) ? body["model"].ToString() : "unknown-model";
            string appName = "APIM-" + (string)context.Variables.GetValueOrDefault("appName", "Gateway");
            string sessionId = context.Request.Headers.GetValueOrDefault("x-session-id", context.RequestId.ToString() ?? "no-id");

            return new JObject(
                new JProperty("session_id", sessionId),
                new JProperty("app_name", appName),
                new JProperty("ai_model", model),
                new JProperty("user_ip", context.Request.IpAddress),
                new JProperty("user_id", context.Request.Headers.GetValueOrDefault("x-user-id", "anonymous"))
            );
        }" />
			<set-variable name="shouldScan" value="@{
            string type = context.Variables.GetValueOrDefault<string>("ScanType", "prompt");
            
            if (type == "prompt") {
                return true; 
            } 
            else if (type == "response") {
                return context.Response != null && context.Response.StatusCode == 200;
            }
            
            return false;
        }" />
			<choose>
				<when condition="@((bool)context.Variables["shouldScan"])">
					<choose>
						<when condition="@(context.Variables.GetValueOrDefault<string>("ScanType", "prompt") == "prompt")">
							<set-variable name="scanContent" value="@{
                            try {
                                var body = context.Request.Body.As<JObject>(preserveContent: true);
                                string content = "";
                                
                                if (body["input"] != null) {
                                    content = body["input"].ToString();
                                } else if (body["messages"] != null) {
                                    var messages = body["messages"] as JArray;
                                    if (messages != null && messages.Count > 0) {
                                        content = messages.Last["content"]?.ToString() ?? "";
                                    }
                                }
                                
                                return content;
                            } catch {
                                return "";
                            }
                        }" />
							<set-variable name="scanDirection" value="IN" />
						</when>
						<otherwise>
							<set-variable name="scanContent" value="@{
                            try {
                                var body = context.Response.Body.As<JObject>(preserveContent: true);
                                string content = "";
                                
                                if (body["output"] != null) {
                                    var output = body["output"] as JArray;
                                    if (output != null && output.Count > 0) {
                                        content = output.Last["content"]?.Last?["text"]?.ToString() ?? "";
                                    }
                                } else if (body["choices"] != null) {
                                    var choices = body["choices"] as JArray;
                                    if (choices != null && choices.Count > 0) {
                                        content = choices.Last["message"]?["content"]?.ToString() ?? "";
                                    }
                                }
                                
                                return content;
                            } catch {
                                return "";
                            }
                        }" />
							<set-variable name="scanDirection" value="OUT" />
						</otherwise>
					</choose>
					<send-request id="aiguard-scan" mode="new" response-variable-name="aiguardScanResponse" timeout="10" ignore-error="true">
						<set-url>@{
                        string cloud = "{{AIGUARD-CLOUD}}";
                        return $"https://api.{cloud}.zseclipse.net/v1/detection/resolve-and-execute-policy";
                    }</set-url>
						<set-method>POST</set-method>
						<set-header name="Authorization" exists-action="override">
							<value>Bearer {{AIGUARD-API-KEY}}</value>
						</set-header>
						<set-header name="Content-Type" exists-action="override">
							<value>application/json</value>
						</set-header>
						<set-body>@{
                        var scanContent = (string)context.Variables.GetValueOrDefault("scanContent", "");
                        var direction = (string)context.Variables.GetValueOrDefault("scanDirection", "IN");
                        
                        var requestBody = new JObject(
                            new JProperty("content", scanContent),
                            new JProperty("direction", direction)
                        );
                        
                        var policyId = context.Variables.GetValueOrDefault<string>("currentPolicy", "");
                        if (!string.IsNullOrEmpty(policyId)) {
                            requestBody.Add("policyId", int.Parse(policyId));
                        }
                        
                        return requestBody.ToString();
                    }</set-body>
					</send-request>
					<choose>
						<when condition="@(context.Variables.ContainsKey("aiguardScanResponse") && ((IResponse)context.Variables["aiguardScanResponse"]).StatusCode == 200)">
							<choose>
								<when condition="@{
                                var resp = ((IResponse)context.Variables["aiguardScanResponse"]).Body.As<JObject>(preserveContent: true);
                                var action = resp["action"]?.ToString() ?? "";
                                return action.Equals("BLOCK", StringComparison.OrdinalIgnoreCase);
                            }">
									<set-variable name="errorBody" value="@{
                                    var aiguardResponse = ((IResponse)context.Variables["aiguardScanResponse"]).Body.As<JObject>(preserveContent: true);
                                    var response = new JObject();

                                    var scanType = context.Variables.GetValueOrDefault<string>("ScanType", "prompt");
                                    if (scanType == "prompt") {
                                        response.Add("error", "ZSCALER AI GUARD SECURITY ALERT: REQUEST BLOCKED");
                                    } else {
                                        response.Add("error", "ZSCALER AI GUARD SECURITY ALERT: RESPONSE BLOCKED");
                                    }

                                    response.Add("action", aiguardResponse["action"]?.ToString() ?? "BLOCK");
                                    response.Add("severity", aiguardResponse["severity"]?.ToString() ?? "unknown");
                                    response.Add("policyName", aiguardResponse["policyName"]?.ToString() ?? "");
                                    response.Add("transactionId", aiguardResponse["transactionId"]?.ToString() ?? "");

                                    var descriptions = context.Variables.GetValueOrDefault<object>("aiguardDescriptions") as JObject;
                                    if (descriptions == null) {   
                                        descriptions = context.Variables.GetValueOrDefault<object>("scanDescriptions") as JObject;
                                    }

                                    var details = new JObject();
                                    var detectors = aiguardResponse["detectorResponses"] as JArray;
                                    if (detectors != null) {
                                        foreach (var detector in detectors) {
                                            var detectorName = detector["detectorName"]?.ToString() ?? "unknown";
                                            var detectorAction = detector["action"]?.ToString() ?? "";
                                            if (detectorAction.Equals("BLOCK", StringComparison.OrdinalIgnoreCase)) {
                                                if (descriptions != null && descriptions[detectorName] != null) {
                                                    details.Add(detectorName, descriptions[detectorName]);
                                                } else {
                                                    details.Add(detectorName, "Blocked by security policy.");
                                                }
                                            }
                                        }
                                    }

                                    response.Add("details", details);
                                    return response.ToString();
                                }" />
									<return-response>
										<set-status code="403" reason="Forbidden" />
										<set-header name="Content-Type" exists-action="override">
											<value>application/json</value>
										</set-header>
										<set-body>@(context.Variables.GetValueOrDefault<string>("errorBody"))</set-body>
									</return-response>
								</when>
							</choose>
						</when>
						<otherwise>
							<choose>
								<when condition="@(Convert.ToBoolean(context.Variables.GetValueOrDefault<object>("FailOpen", false)) == false)">
									<return-response>
										<set-status code="503" reason="Service Unavailable" />
										<set-header name="Content-Type" exists-action="override">
											<value>application/json</value>
										</set-header>
										<set-body>{ "error": "ZSCALER AI GUARD: Security scanner unavailable. Request blocked for safety." }</set-body>
									</return-response>
								</when>
								<otherwise>
									<trace source="ZscalerAIGuard" severity="error">
										<message>AI Guard scanner unavailable. Failing open (allowing traffic).</message>
									</trace>
								</otherwise>
							</choose>
						</otherwise>
					</choose>
				</when>
				<otherwise>
					<trace source="ZscalerAIGuard" severity="error">
						<message>Inherited an Error</message>
					</trace>
					<set-body>@(context.Response.Body.As<string>(preserveContent: true))</set-body>
				</otherwise>
			</choose>
		</when>
		<otherwise>
		</otherwise>
	</choose>
</fragment>
