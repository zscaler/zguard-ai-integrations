# Zscaler AI Guard
AIGUARD_API_KEY=<YOUR_AIGUARD_API_KEY>
AIGUARD_CLOUD=us1

# Portkey Gateway (optional, defaults to http://127.0.0.1:8787)
# PORTKEY_GATEWAY_URL=http://127.0.0.1:8787

# Anthropic
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>

# Azure OpenAI
AZURE_OPENAI_API_KEY=<AZURE_KEY>
AZURE_RESOURCE=<AZURE_RESOURCE_NAME>
AZURE_DEPLOYMENT=<AZURE_DEPLOYMENT_NAME>
AZURE_API_VERSION=<AZURE_API_VERSION>

# AWS Bedrock
AWS_ACCESS_KEY_ID=<AWS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<AWS_SECRET_KEY>
AWS_REGION=<AWS_REGION>

# Google Vertex AI
GOOGLE_CLOUD_PROJECT_ID=<PROJECT_ID>
GOOGLE_CLOUD_REGION=<REGION>
VERTEX_SERVICE_ACCOUNT_FILE=<PATH_TO_SERVICE_ACCOUNT_JSON>
