# Zscaler AI Guard Configuration for Cursor Security Hooks
# Copy this file to .env in your project root and configure your settings.

# ============================================
# REQUIRED: AI Guard API Key
# ============================================

# Your Zscaler AI Guard API key (Bearer token)
# Obtain from: AI Guard Console → Private AI Apps → App API Keys
AIGUARD_API_KEY="your-aiguard-api-key-here"

# ============================================
# OPTIONAL: Cloud Region
# ============================================

# Zscaler cloud for your tenancy (default: us1)
# Builds API URL: https://api.{cloud}.zseclipse.net
# AIGUARD_CLOUD="us1"

# ============================================
# OPTIONAL: URL Override
# ============================================

# Override the API base URL entirely (ignores AIGUARD_CLOUD when set)
# Equivalent to AIGUARD_OVERRIDE_URL in the Python SDK
# AIGUARD_OVERRIDE_URL="https://api.custom.zseclipse.net"

# ============================================
# OPTIONAL: Policy ID
# ============================================

# Specific policy ID. When set, uses /v1/detection/execute-policy.
# When empty, uses /v1/detection/resolve-and-execute-policy for
# automatic policy resolution linked to your API key.
# AIGUARD_POLICY_ID="760"

# ============================================
# USAGE
# ============================================

# 1. Copy to either location (both are supported):
#    cp example.env .env                    # workspace root (repo root)
#    cp example.env Cursor/.env             # next to this integration
#
# 2. Edit .env with your API key
#
# 3. The hook scripts auto-load .env from the workspace root first, then
#    Cursor/.env. Shell exports still work for manual terminal tests.
#    Alternatively, export in your shell profile:
#    echo 'export AIGUARD_API_KEY="your-key"' >> ~/.zshrc
#
# 4. Restart Cursor to activate hooks.

# ============================================
# SECURITY NOTES
# ============================================

# - NEVER commit .env to version control
# - Add .env to your .gitignore
# - Rotate API keys per your organization's policy
# - Monitor aiguard.log for scan events and false positives
# - Logs are written to Cursor/hooks/aiguard.log
