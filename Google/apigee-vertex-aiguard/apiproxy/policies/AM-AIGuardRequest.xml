<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<AssignMessage name="AM-AIGuardRequest">
  <Set>
    <Headers>
      <Header name="Content-Type">application/json</Header>
      <Header name="Authorization">Bearer {private.aiguard.apikey}</Header>
    </Headers>
    <Payload contentType="application/json">{aiguard.request.payload}</Payload>
    <Verb>POST</Verb>
  </Set>
  <AssignTo createNew="true" type="request">aiguard.request</AssignTo>
</AssignMessage>
