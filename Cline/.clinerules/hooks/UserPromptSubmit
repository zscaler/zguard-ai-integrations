#!/usr/bin/env python3
"""Cline UserPromptSubmit — Zscaler AI Guard scan (direction IN)."""

from __future__ import annotations

import json
import sys

from aiguard_utils import (
    MAX_POST_CHARS,
    block_message,
    get_client_config,
    log_message,
    respond_json,
    scan_content,
    truncate_text,
)


def main() -> int:
    try:
        raw = sys.stdin.read()
        data = json.loads(raw) if raw.strip() else {}
    except json.JSONDecodeError:
        respond_json(False)
        return 0

    ups = data.get("userPromptSubmit") or {}
    prompt = ups.get("prompt") or ""
    if not prompt:
        respond_json(False)
        return 0

    text = truncate_text(prompt, MAX_POST_CHARS)
    log_message(f"UserPromptSubmit: scanning ({len(text)} chars)")

    if not get_client_config().get("api_key"):
        log_message("WARNING: AIGUARD_API_KEY not set — allowing without scan")
        respond_json(False)
        return 0

    r = scan_content(text, "IN")
    if r.get("error"):
        log_message(f"UserPromptSubmit: API error (fail-closed): {r['error']}")
        respond_json(True, f"Zscaler AI Guard scan failed: {r['error']}")
        return 0

    action = r.get("action") or "ALLOW"
    if action not in ("ALLOW", "BLOCK", "DETECT"):
        log_message("UserPromptSubmit: invalid action (fail-closed)")
        respond_json(
            True,
            "Zscaler AI Guard returned an unexpected response; blocked for safety.",
        )
        return 0

    if action == "BLOCK":
        bd = ",".join(r.get("blocking_detectors") or [])
        log_message(
            f"BLOCKED USER INPUT: policy={r.get('policy_name')} "
            f"detectors=[{bd}] txn={r.get('transaction_id')}"
        )
        respond_json(True, block_message(r, "user prompt"))
        return 0

    det = r.get("triggered_detectors") or []
    if det:
        log_message(
            f"ALLOWED USER INPUT: action={action} detected=[{','.join(det)}] "
            f"txn={r.get('transaction_id')}"
        )
    respond_json(False)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
