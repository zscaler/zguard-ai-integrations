#!/usr/bin/env python3
"""Cline PostToolUse — Zscaler AI Guard scan of tool output (direction OUT)."""

from __future__ import annotations

import json
import sys

from aiguard_utils import (
    block_message,
    extract_post_tool_scan,
    get_client_config,
    log_message,
    respond_json,
    scan_content,
)


def main() -> int:
    try:
        data = json.loads(sys.stdin.read() or "{}")
    except json.JSONDecodeError:
        respond_json(False)
        return 0

    content, tool_label = extract_post_tool_scan(data)
    if len(content) < 10:
        log_message(f"PostToolUse: content too short for {tool_label} — allowing")
        respond_json(False)
        return 0

    log_message(f"PostToolUse: scanning {tool_label} ({len(content)} chars)")

    if not get_client_config().get("api_key"):
        log_message("WARNING: AIGUARD_API_KEY not set — allowing without scan")
        respond_json(False)
        return 0

    r = scan_content(content, "OUT")
    if r.get("error"):
        log_message(f"PostToolUse: API error (fail-closed): {r['error']}")
        respond_json(True, f"Zscaler AI Guard scan failed: {r['error']}")
        return 0

    action = r.get("action") or "ALLOW"
    if action not in ("ALLOW", "BLOCK", "DETECT"):
        log_message("PostToolUse: invalid action (fail-closed)")
        respond_json(
            True,
            "Zscaler AI Guard returned an unexpected response; blocked for safety.",
        )
        return 0

    if action == "BLOCK":
        bd = ",".join(r.get("blocking_detectors") or [])
        log_message(
            f"BLOCKED PostToolUse {tool_label}: detectors=[{bd}] txn={r.get('transaction_id')}"
        )
        respond_json(True, block_message(r, f"tool output ({tool_label})"))
        return 0

    det = r.get("triggered_detectors") or []
    if det:
        log_message(
            f"PostToolUse {tool_label}: detected=[{','.join(det)}] "
            f"txn={r.get('transaction_id')}"
        )
    respond_json(False)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
