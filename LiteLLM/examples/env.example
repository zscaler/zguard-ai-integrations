# This file contains secret keys. Add it to your .gitignore!

# ZSCALER AI GUARD — SDK callback (Option B)
AIGUARD_API_KEY=<YOUR_AIGUARD_API_KEY>
AIGUARD_CLOUD=us1

# ZSCALER AI GUARD — Native plugin (Option A)
ZSCALER_AI_GUARD_API_KEY=<YOUR_AIGUARD_API_KEY>
# ZSCALER_AI_GUARD_POLICY_ID=<OPTIONAL_POLICY_ID>
# ZSCALER_AI_GUARD_URL=https://api.us1.zseclipse.net/v1/detection/execute-policy

# ANTHROPIC
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>

# AZURE
AZURE_OPENAI_API_KEY=<AZURE_OPENAI_API_KEY>
AZURE_RESOURCE=<AZURE_RESOURCE_NAME>
AZURE_DEPLOYMENT=<AZURE_DEPLOYMENT_NAME>
AZURE_API_VERSION=<AZURE_API_VERSION>

# AWS
AWS_ACCESS_KEY_ID=<AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<AWS_SECRET_ACCESS_KEY>
AWS_REGION=<AWS_REGION>

# LITELLM
LITELLM_MASTER_KEY=sk-1234
