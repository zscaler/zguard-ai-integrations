# Copy to .env for local runs (optional). Jenkins uses credentials + parameters.
# .env is gitignored.

# Zscaler AI Guard (required for scan_policy.py)
AIGUARD_API_KEY=
AIGUARD_CLOUD=us1
# Optional — numeric ID; if unset, uses resolve-and-execute-policy
AIGUARD_POLICY_ID=
AIGUARD_TIMEOUT=30

# Google Cloud (Vertex AI deploy / test — optional for scan-only jobs)
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
# Local: path to service account JSON; Jenkins uses gcp-sa-key credential file
GOOGLE_APPLICATION_CREDENTIALS=

HF_TOKEN=
