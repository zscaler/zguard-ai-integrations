# Copy this file to .env and fill in your values.
# .env is gitignored and will not be committed.
#
# These correspond to the GitHub Secrets needed by the CI/CD pipeline.

# ============================================
# REQUIRED: Zscaler AI Guard
# ============================================

# AI Guard API key (Bearer token)
# Obtain from: AI Guard Console → Private AI Apps → App API Keys
AIGUARD_API_KEY=your-aiguard-api-key

# ============================================
# OPTIONAL: Zscaler AI Guard
# ============================================

# Cloud region (default: us1). Builds URL: https://api.{cloud}.zseclipse.net
# AIGUARD_CLOUD=us1

# Specific policy ID. When set, uses /v1/detection/execute-policy.
# When empty, uses /v1/detection/resolve-and-execute-policy.
# AIGUARD_POLICY_ID=760

# API timeout in seconds (default: 30)
# AIGUARD_TIMEOUT=30

# ============================================
# OPTIONAL: Google Cloud (example deployment target)
# ============================================

# GCP_PROJECT_ID=your-project-id
# GCP_REGION=us-central1
# GCP_SA_KEY=                          # Path to or contents of service account JSON key

# ============================================
# OPTIONAL: HuggingFace (for gated models)
# ============================================

# HF_TOKEN=your-huggingface-token
