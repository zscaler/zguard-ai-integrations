# Zscaler AI Guard Configuration
# Copy this file to .env and fill in your credentials

# Required: API key from AI Guard Console
# Generate at: AI Guard Console > Private AI Apps > App API Keys
AIGUARD_API_KEY=your-api-key-here

# Optional: Cloud region
# Options: us1 (default), us2, eu1, eu2
AIGUARD_CLOUD=us1

# Optional: Specific policy ID
# If not set, the SDK auto-resolves the active policy
# AIGUARD_POLICY_ID=12345

# Optional: Request timeout in seconds (default: 30)
# AIGUARD_TIMEOUT=30
