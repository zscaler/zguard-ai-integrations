# Zscaler AI Guard Configuration
# Copy this file to .env and fill in your credentials

# API Key (Required)
# Get this from AI Guard Console → Private AI Apps → App API Keys
AIGUARD_API_KEY=your_api_key_here

# Cloud Environment (Required)
# Options: us1, us2, eu1, eu2
AIGUARD_CLOUD=us1

# Policy ID (Optional)
# If not provided, policy will be auto-resolved based on API key/application association
# To find: AI Guard Console → Policies → View your policy details
AIGUARD_POLICY_ID=

# Timeout in seconds (Optional, default: 30)
AIGUARD_TIMEOUT=30
